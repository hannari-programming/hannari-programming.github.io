---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n';

const t = useTranslations('zh');
---
<Base>
  <section class="relative overflow-hidden min-h-[80vh] flex items-center">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/4 -right-20 w-96 h-96 bg-hannari-pink/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 -left-20 w-80 h-80 bg-hannari-gold/10 rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-5xl mx-auto px-6 py-24 relative">
      <div class="mb-8">
        <h1 id="hero-title" class="font-display text-6xl md:text-8xl font-black leading-none tracking-tight text-hannari-ink opacity-0">
          <span class="block">Hannari</span>
          <span class="block text-hannari-pink">Programming</span>
        </h1>
      </div>
      <p class="font-body text-xl text-hannari-ink/60 mb-2 opacity-0 animate-fade-up" style="animation-delay:0.6s; animation-fill-mode:forwards;">
        {t('hero.tagline')}
      </p>
      <div class="flex gap-6 mt-6 text-sm text-hannari-mauve opacity-0 animate-fade-up" style="animation-delay:0.8s; animation-fill-mode:forwards;">
        <span class="border border-hannari-mauve/30 rounded-full px-4 py-1">{t('hero.since')}</span>
        <span class="border border-hannari-pink/30 rounded-full px-4 py-1 text-hannari-pink">{t('hero.members')}</span>
      </div>

      <!-- 中国語コンテンツ募集中のお知らせ -->
      <div class="mt-12 border border-hannari-gold/30 rounded-2xl p-6 bg-hannari-gold/5 max-w-lg">
        <p class="text-hannari-gold font-body text-sm">
          🙋 中文内容正在准备中。欢迎会中文的成员来贡献翻译！<br/>
          <a href="https://github.com/hannari-programming/hannari-programming.github.io/issues" target="_blank" rel="noopener" class="underline hover:text-hannari-pink mt-2 inline-block">
            → 在 GitHub 上贡献
          </a>
        </p>
      </div>
    </div>
  </section>
</Base>

<script>
const title = document.getElementById('hero-title');
if (title) {
  title.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
  title.style.transform  = 'translateY(30px)';
  requestAnimationFrame(() => {
    setTimeout(() => { title.style.opacity = '1'; title.style.transform = 'translateY(0)'; }, 100);
  });
}
</script>
